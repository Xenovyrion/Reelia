<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Needed to launch the system package installer ourselves for in-app update installs,
         since Reelia isn't distributed through the Play Store. -->
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />

    <!-- allowBackup=false: Android's default Auto Backup restores Room/DataStore/Firebase
         Auth's session file on reinstall from a stale Google Drive snapshot — this silently
         undid "reset library" (a fresh install looked auto-signed-in with the pre-reset data
         back) and is redundant anyway since everything meaningful already syncs via Firestore. -->
    <application
        android:name=".TimeLineApplication"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.TimeLine">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.TimeLine">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
    </application>

</manifest>
